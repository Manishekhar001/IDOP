# IDOP — Intelligent Data Operations Platform
# Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────

# ── General App Configuration ──────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=*

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=your-secure-random-secret-here

# ── LLM Provider ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
LLM_PROVIDER=litellm
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
MEMORY_LLM_MODEL=llama-3.3-70b-versatile
MEMORY_LLM_TEMPERATURE=0.0
VANNA_LLM_MODEL=gpt-4o-mini
# GROQ_API_KEY_1=
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=
# GROQ_API_KEY_4=

# ── Embedding Provider ─────────────────────────────────────────────────
EMBEDDING_PROVIDER=nomic
NOMIC_API_KEY=your-nomic-api-key-here
# NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5
# NOMIC_EMBEDDING_DIMENSION=768
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-3
# VOYAGE_EMBEDDING_DIMENSION=1024

# ── Qdrant Vector Database ─────────────────────────────────────────────
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here
# COLLECTION_NAME=idop_documents

# ── Relational Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# SUPABASE_DB_URL=postgresql+psycopg://postgres.ref:pass@host:5432/postgres

# ── Document Cache (S3 or Local) ───────────────────────────────────────
STORAGE_BACKEND=local
CACHE_DIR=data/cached_chunks
# S3_CACHE_BUCKET=idop-cache-docs
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Query Cache (Upstash Redis) ────────────────────────────────────────
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=
# CACHE_TTL_EMBEDDINGS=604800
# CACHE_TTL_RAG=3600
# CACHE_TTL_SQL_GEN=86400
# CACHE_TTL_SQL_RESULT=900

# ── Search and Reranking ───────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here
# TAVILY_MAX_RESULTS=5

# ── LangGraph State Configuration ──────────────────────────────────────
# STM_MESSAGE_THRESHOLD=6
# CRAG_UPPER_THRESHOLD=0.7
# CRAG_LOWER_THRESHOLD=0.3
# SRAG_MAX_RETRIES=2
# MAX_REWRITE_TRIES=2
# RETRIEVAL_K=5

# ── Chunking ───────────────────────────────────────────────────────────
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# ── Opik Observability ────────────────────────────────────────────────
# OPIK_API_KEY=
# OPIK_WORKSPACE=
# OPIK_PROJECT_NAME=idop
