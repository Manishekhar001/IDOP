# ==================== IDOP Environment Configuration ====================

# Application Details
APP_NAME="Intelligent Data Operations Platform (IDOP)"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # Options: development, production
LOG_LEVEL="INFO"
API_HOST="0.0.0.0"
API_PORT=8000

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key"
LLM_MODEL="gpt-4o"                  # Used for complex generation tasks
LLM_TEMPERATURE=0.0
MEMORY_LLM_MODEL="gpt-4o-mini"       # Used for routing and smaller sub-nodes
MEMORY_LLM_TEMPERATURE=0.0

# Vector Database (Qdrant)
QDRANT_URL="https://your-qdrant-instance.aws.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"
COLLECTION_NAME="idop_documents"
EMBEDDING_DIMENSION=1536            # Standard 1536 for text-embedding-3-small

# Relational Database (PostgreSQL / Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/idop_memories"
SUPABASE_DB_URL="postgresql://postgres:supabase_password@your-supabase-host:5432/postgres"

# Model Context Protocol (MCP) Configuration (optional)
MCP_ENABLED=true

# Caching Configuration
# 1. Document Level Caching (S3 / Local)
STORAGE_BACKEND="local"             # Options: local, s3
S3_CACHE_BUCKET="your-s3-bucket"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"

# 2. Query Level Caching (Upstash Redis)
UPSTASH_REDIS_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_TOKEN="your-upstash-redis-token"

# Cache TTL Configuration (in seconds)
CACHE_TTL_EMBEDDINGS=604800         # 7 days
CACHE_TTL_RAG=3600                  # 1 hour
CACHE_TTL_SQL_GEN=86400             # 24 hours
CACHE_TTL_SQL_RESULT=900            # 15 minutes

# Web Search API (Tavily)
TAVILY_API_KEY="your-tavily-api-key"
TAVILY_MAX_RESULTS=5

# Reranking API (Voyage AI)
VOYAGE_API_KEY="your-voyage-api-key"

# LangSmith Monitoring (optional)
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="idop"
