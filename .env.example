# ==================== IDOP Environment Configuration ====================

# Application Details
APP_NAME='Intelligent Data Operations Platform (IDOP)'
APP_VERSION='0.1.0'
ENVIRONMENT='development'
LOG_LEVEL='INFO'
API_HOST='0.0.0.0'
API_PORT=8000

# LLM Provider - LiteLLM Router
# Priority: Groq keys -> ChatOpenAI fallback
LLM_PROVIDER=litellm
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
MEMORY_LLM_MODEL=llama-3.3-70b-versatile
MEMORY_LLM_TEMPERATURE=0.0

OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY_1=your-groq-api-key-1
GROQ_API_KEY_2=your-groq-api-key-2
GROQ_API_KEY_3=your-groq-api-key-3
GROQ_API_KEY_4=your-groq-api-key-4

# Vanna Text-to-SQL (uses OpenAI internally)
# Vanna's OpenAILlmService uses this model for SQL generation.
# Must be an actual OpenAI model name (not a Groq model).
VANNA_LLM_MODEL=gpt-4o-mini

# Embedding Provider - Nomic (default) / Voyage AI
EMBEDDING_PROVIDER=nomic
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_EMBEDDING_MODEL=voyage-3
NOMIC_API_KEY=your-nomic-api-key
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5
NOMIC_EMBEDDING_DIMENSION=768
EMBEDDING_DIMENSION=768

# Vector Database
QDRANT_URL=https://your-qdrant-instance.aws.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
COLLECTION_NAME=idop_documents

# Relational Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/idop_memories
SUPABASE_DB_URL=postgresql://postgres:supabase_password@your-supabase-host:5432/postgres

# Caching
STORAGE_BACKEND=s3
S3_CACHE_BUCKET=your-s3-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
UPSTASH_REDIS_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token
CACHE_TTL_EMBEDDINGS=604800
CACHE_TTL_RAG=3600
CACHE_TTL_SQL_GEN=86400
CACHE_TTL_SQL_RESULT=900

# Web Search & Reranking
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=5

# Observability
OPIK_API_KEY=your-opik-api-key
OPIK_PROJECT_NAME=idop-Project
OPIK_WORKSPACE=default
OPIK_TRACK_DISABLE=false
